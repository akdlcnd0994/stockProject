<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.stockproject.mapper.StockMapper">

    <select id="selectAllUsers" resultType="com.example.stockproject.dto.StockDto">
        SELECT * FROM stock_data
    </select>

    <select id="selectUserById" parameterType="Long" resultType="com.example.stockproject.dto.StockDto">
        SELECT * FROM stock_data WHERE id = #{id}
    </select>

</mapper>